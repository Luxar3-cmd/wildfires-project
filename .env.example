# ============================================================
# Plantilla de variables de entorno
# Copia a .env y completa los valores. NO commitear .env.
# ============================================================

# CONAF / itrend - Plataforma de Datos para la Resiliencia (Dataverse)
# Obtén tu API key en: https://datospararesiliencia.cl/dataverseuser.xhtml
# (regístrate → API Token → "Create Token").
ITREND_API_KEY=
# Opcional: cambiar solo si la base URL cambia
ITREND_BASE_URL=https://datospararesiliencia.cl

# Copernicus Climate Data Store (CDS)
# Registro: https://cds.climate.copernicus.eu/user/register
# Aceptar términos de ERA5-Land en la página del dataset (botón al final del form).
# Tu API key (UUID) está en https://cds.climate.copernicus.eu/profile
#
# RECOMENDADO: configurar ~/.cdsapirc en vez de estas vars (formato oficial).
# Si defines CDSAPI_KEY aquí, sobrescribe a ~/.cdsapirc en este proyecto.
# Si queda vacío, se ignora.
CDSAPI_URL=https://cds.climate.copernicus.eu/api
CDSAPI_KEY=

# NASA FIRMS - MODIS Fire Radiative Power (para el label L2)
# Obtén tu MAP_KEY gratuita en: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# (solo requiere email; sin registro pesado).
FIRMS_MAP_KEY=
# Opcional: cambiar solo si el endpoint cambia
FIRMS_BASE_URL=https://firms.modaps.eosdis.nasa.gov/api/area/csv
